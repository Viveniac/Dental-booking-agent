# LLM Provider (gemini, bedrock, openai, anthropic, groq)
LLM_PROVIDER=gemini

# Google Gemini (FREE - get key from https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Amazon Bedrock Nova (FREE tier available)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Other providers
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Calendly
CALENDLY_API_TOKEN=your_calendly_api_token_here
